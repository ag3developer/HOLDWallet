{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/docs", "destination": "/index.html" },
    { "source": "/docs/(.*)", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/register", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/index.html" },
    { "source": "/checkout/(.*)", "destination": "/index.html" },
    { "source": "/api-keys", "destination": "/index.html" },
    { "source": "/webhooks", "destination": "/index.html" },
    { "source": "/payments", "destination": "/index.html" },
    { "source": "/payments/(.*)", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|favicon\\.ico|manifest\\.json|images/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
